# ClamAV binary path overrides (optional)
# Leave blank to use system PATH auto-detection

# Windows example: C:\Program Files\ClamAV\clamscan.exe
CLAMAV_CLAMSCAN_PATH=

# macOS/Linux example: /opt/homebrew/bin/clamscan
# CLAMAV_CLAMSCAN_PATH=/usr/local/bin/clamscan

# Directory used for quarantine storage (default: <userData>/quarantine)
QUARANTINE_DIR=

# Maximum number of scan history entries to keep
MAX_HISTORY_ENTRIES=50

# Log level: error | warn | info | verbose | debug
LOG_LEVEL=info
